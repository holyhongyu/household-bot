# Get this from @BotFather on Telegram after creating your bot
BOT_TOKEN=123456789:AAExampleTokenReplaceMe

# SQLite file path - relative to where the bot runs. Railway gives you a
# persistent volume, so mount it there in production (see README).
DATABASE_URL=sqlite:///household.db

# IANA timezone name for reminder scheduling (e.g. "Australia/Sydney",
# "America/New_York", "Europe/London"). All "Today 9am" style reminders
# are interpreted in this timezone.
TIMEZONE=UTC

# The Telegram chat ID of your shared group chat. Leave blank until you've
# added the bot to your group and run /chatid there - the bot will print it.
GROUP_CHAT_ID=
